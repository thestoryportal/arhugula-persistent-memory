{
  "hooks": {
    "SessionStart": [{ "matcher": "startup|resume|clear|compact", "hooks": [
      { "type": "command", "command": "/usr/bin/python3 \"/workspace/.codex/hooks/session_start.py\"", "statusMessage": "Loading project posture + preflight", "timeout": 90 } ] }],
    "PreToolUse": [{ "matcher": "Bash|apply_patch|Edit|Write", "hooks": [
      { "type": "command", "command": "/usr/bin/python3 \"/workspace/.codex/hooks/pre_tool_use_policy.py\"", "statusMessage": "Checking LAWs / boundaries", "timeout": 15 } ] }],
    "PermissionRequest": [{ "matcher": "*", "hooks": [
      { "type": "command", "command": "/usr/bin/python3 \"/workspace/.codex/hooks/permission_request.py\"", "statusMessage": "Reviewing permission", "timeout": 15 } ] }],
    "Stop": [{ "hooks": [
      { "type": "command", "command": "/usr/bin/python3 \"/workspace/.codex/hooks/stop_gate.py\"", "statusMessage": "Checking stop posture", "timeout": 90 } ] }]
  }
}
