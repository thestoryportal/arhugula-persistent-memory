abstract = {S2 TL;DR: The mechanisms underlying factual knowledge recall in autoregressive transformer language models are investigated, a causal intervention for identifying neuron activations capable of altering a model’s factual predictions are developed, and the distinction between saying and knowing neurons is clarified.},
